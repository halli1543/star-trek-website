<%- include('partials/header') %>

<div class="shows-grid">
  <% shows.forEach(show => { %>
    <a href="/shows/<%= show.id %>" class="show-card">
      <% if (show.image) { %>
        <img class="show-card__image" src="<%= show.image %>" alt="<%= show.title %>">
      <% } %>
      <div class="show-card__body">
        <h3 class="show-card__title"><%= show.title %></h3>
        <p class="show-card__meta"><%= show.year %> · <%= show.seasons %> seasons</p>
      </div>
    </a>
  <% }) %>
</div>

<%- include('partials/footer') %>